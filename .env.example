# Copy this file to .env and fill in your values.
# Only configure the provider or local runtime you plan to use.
# cp .env.example .env

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

DISCOVERY_QUERY_MODEL=gpt-4o-mini
DISCOVERY_RANK_MODEL=gpt-4o-mini
ANALYSIS_MODEL=gpt-4o-mini
CHAT_MODEL=gpt-4o-mini
COMPARE_PROFILE_MODEL=gpt-4o-mini
COMPARE_SYNTHESIS_MODEL=gpt-4o
IDEA_GENERATION_MODEL=gpt-4o-mini
IDEA_CRITIQUE_MODEL=gpt-4o-mini

OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=

ANTHROPIC_API_KEY=

GOOGLE_API_KEY=

OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=

OLLAMA_BASE_URL=http://localhost:11434
LOCAL_EMBEDDING_DEVICE=
